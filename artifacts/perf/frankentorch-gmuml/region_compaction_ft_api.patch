+    fn compact_nograd_tensor_since(
+        &mut self,
+        boundary: usize,
+        output: TensorNodeId,
+    ) -> Result<TensorNodeId, AutogradError> {
+        if output.0 < boundary || self.tensor_requires_grad(output)? {
+            return Ok(output);
+        }
+
+        let shape = self.tensor_shape(output)?;
+        match self.tensor_dtype(output)? {
+            DType::F64 => {
+                let values = self.tensor_values(output)?;
+                self.truncate_autograd_graph(boundary);
+                self.tensor_variable(values, shape, false)
+            }
+            DType::F32 => {
+                let values = self.tensor_values_f32(output)?;
+                self.truncate_autograd_graph(boundary);
+                self.tensor_variable_f32(values, shape, false)
+            }
+            _ => Ok(output),
+        }
+    }
