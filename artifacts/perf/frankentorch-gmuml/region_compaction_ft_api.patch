+    #[test]
+    fn functional_conv1d_nograd_compacts_intermediates_bit_exact() {
+        let input_values: Vec<f64> = (0..30).map(|i| (i as f64 - 11.0) * 0.125).collect();
+        let weight_values: Vec<f64> = (0..12).map(|i| (i as f64 - 5.0) * 0.2).collect();
+        let bias_values = vec![0.25, -0.5];
+
+        let mut compact = FrankenTorchSession::new(ExecutionMode::Strict);
+        let compact_input = compact
+            .tensor_variable(input_values.clone(), vec![2, 3, 5], false)
+            .unwrap();
+        let compact_weight = compact
+            .tensor_variable(weight_values.clone(), vec![2, 3, 2], false)
+            .unwrap();
+        let compact_bias = compact
+            .tensor_variable(bias_values.clone(), vec![2], false)
+            .unwrap();
+        let boundary = compact.autograd_graph_node_count();
+        let compact_out = compact
+            .functional_conv1d(compact_input, compact_weight, Some(compact_bias), 1, 1)
+            .unwrap();
+        let compact_values = compact.tensor_values(compact_out).unwrap();
+        assert_eq!(compact.tensor_shape(compact_out).unwrap(), vec![2, 2, 6]);
+        assert!(!compact.tensor_requires_grad(compact_out).unwrap());
+        assert_eq!(compact.autograd_graph_node_count(), boundary + 1);
+
+        let mut reference = FrankenTorchSession::new(ExecutionMode::Strict);
+        let reference_input = reference
+            .tensor_variable(input_values, vec![2, 3, 5], true)
+            .unwrap();
+        let reference_weight = reference
+            .tensor_variable(weight_values, vec![2, 3, 2], true)
+            .unwrap();
+        let reference_bias = reference.tensor_variable(bias_values, vec![2], true).unwrap();
+        let reference_out = reference
+            .functional_conv1d(reference_input, reference_weight, Some(reference_bias), 1, 1)
+            .unwrap();
+        assert!(reference.tensor_requires_grad(reference_out).unwrap());
+        assert_eq!(compact_values, reference.tensor_values(reference_out).unwrap());
+    }
